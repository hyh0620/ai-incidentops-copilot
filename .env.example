DATABASE_URL=sqlite:///./incidentops.db
AUTH_MODE=demo
ALLOW_DEV_CREATE_ALL=false
BOOTSTRAP_DEMO_DATA=false

# Frontend browser-side API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Frontend server-side API URL, useful in Docker where backend service name is "backend"
API_BASE_URL=http://localhost:8000

# Default providers run fully offline. Optional paid/API providers must be enabled explicitly.
LLM_PROVIDER=none
TRIAGE_PROVIDER=rule_fallback
VISION_PROVIDER=none
OCR_PROVIDER=pytesseract_ocr
OCR_REQUIRED_LANGUAGES=eng,chi_sim

# Retrieval defaults: local hash embeddings + FAISS + BM25 + RRF + heuristic reranker.
EMBEDDING_PROVIDER=local_hash_embedding_fallback
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
RERANKER_PROVIDER=heuristic_reranker
RERANKER_MODEL=
VECTOR_INDEX_DIR=app/vector_store
RETRIEVAL_TOP_K=3
RETRIEVAL_CANDIDATE_POOL=12
MIN_EVIDENCE_THRESHOLD=0.035
ALLOW_AUTO_REBUILD_INDEX=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
MAX_UPLOAD_BYTES=10485760
ENABLE_PII_REDACTION=true
REDACT_INTERNAL_IPS=false

# Evaluation quality gates for the synthetic fixture regression benchmark.
EVALUATION_MIN_CATEGORY_ACCURACY=0.80
EVALUATION_MIN_HITRATE_AT_3=0.80
EVALUATION_MIN_SEVERITY_EXACT_MATCH=0.70
EVALUATION_MIN_SECURITY_REVIEW_RECALL=0.80
EVALUATION_MIN_CITATION_GROUNDING_RATE=0.70
EVALUATION_MAX_FALSE_AUTO_APPROVAL_RATE=0.10

# Optional OpenAI-compatible providers. The default offline app does not call them.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
